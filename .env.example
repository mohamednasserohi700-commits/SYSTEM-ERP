# ==========================================
# ProERP - Environment Variables
# ==========================================
# انسخ هذا الملف إلى .env وعدّل القيم

# مفتاح الأمان - غيّره لقيمة عشوائية قوية
SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production

# قاعدة البيانات
# للتطوير المحلي: SQLite
DATABASE_URL=sqlite:///erp.db

# للإنتاج على سيرفر PostgreSQL:
# DATABASE_URL=postgresql://username:password@host:5432/erp_db

# بيئة التشغيل
FLASK_ENV=production
PORT=5000
